root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
max_line_length = 120
tab_width = 2
trim_trailing_whitespace = true

[Makefile]
indent_style = tab

[**/*.{css,scss,js,ts,json}]
indent_style = space

[.babelrc,.bowerrc,.browserslistrc,.postcssrc,**/*.{md,yml,rb}]
indent_style = space

[*.md]
trim_trailing_whitespace = false
max_line_length = off
indent_size = unset

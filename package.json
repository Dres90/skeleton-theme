{
  "name": "px-shopify-starter-theme",
  "version": "1.0.0",
  "description": "A starter theme for Shopify",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint:css": "stylelint 'src/css/**/*.css'",
    "lint:js": "eslint 'src/js/**/*.js'",
    "lint": "npm run lint:css && npm run lint:js",
    "build:css": "gulp css",
    "watch:css": "gulp watch",
    "build": "gulp build",
    "watch": "gulp watch",
    "build:css:postcss": "postcss src/**/*.css !src/**/_*.css --dir assets --map",
    "watch:css:postcss": "postcss src/**/*.css !src/**/_*.css --dir assets --watch --map",
    "format": "prettier --write '**/*.{js,json,css,liquid}'"
  },
  "keywords": [
    "shopify",
    "theme",
    "starter"
  ],
  "author": "PX",
  "license": "ISC",
  "devDependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "gulp": "^5.0.1",
    "gulp-flatten": "^0.4.0",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^10.0.0",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-touch-fd": "^2.0.0",
    "postcss": "^8.5.8",
    "postcss-at-rules-variables": "^0.3.0",
    "postcss-bem": "^0.4.1",
    "postcss-calc": "^10.1.1",
    "postcss-each": "^1.1.0",
    "postcss-functions": "^4.0.2",
    "postcss-hexrgba": "^2.1.0",
    "postcss-import": "^16.1.1",
    "postcss-mixins": "^12.1.2",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.0",
    "postcss-pxtorem": "^6.1.0",
    "postcss-simple-vars": "^7.0.1",
    "rollup": "^4.59.0",
    "stylelint": "^17.5.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
